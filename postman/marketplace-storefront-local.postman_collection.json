    {
      "name": "Guest Cart",
      "item": [
        {
          "name": "Get/Create Guest Cart",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Cart-Session",
                "value": "{{guestSessionKey}}"
              }
            ],
            "url": "{{baseUrl}}/api/storefront/guest/cart",
            "description": ""
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Guest cart status is 200', function () { pm.expect(pm.response.code).to.eql(200); });",
                  "const json = pm.response.json();",
                  "if (json?.data?.sessionKey) pm.collectionVariables.set('guestSessionKey', json.data.sessionKey);",
                  "if (json?.data?.items?.length) pm.collectionVariables.set('guestItemId', String(json.data.items[0].id));"
                ]
              }
            }
          ]
        },
        {
          "name": "Add Guest Cart Item",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Cart-Session",
                "value": "{{guestSessionKey}}"
              }
            ],
            "url": "{{baseUrl}}/api/storefront/guest/cart/items",
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"qty\": 1,\n  \"notes\": \"Postman guest item\",\n  \"variant\": {\n    \"size\": \"default\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Add guest item status is 200', function () { pm.expect(pm.response.code).to.eql(200); });",
                  "const json = pm.response.json();",
                  "if (json?.data?.sessionKey) pm.collectionVariables.set('guestSessionKey', json.data.sessionKey);",
                  "if (json?.data?.items?.length) {",
                  "  const productId = Number(pm.collectionVariables.get('productId'));",
                  "  const match = json.data.items.find(i => i.product && i.product.id === productId) || json.data.items[0];",
                  "  pm.collectionVariables.set('guestItemId', String(match.id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Guest Cart Item Qty",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Cart-Session",
                "value": "{{guestSessionKey}}"
              }
            ],
            "url": "{{baseUrl}}/api/storefront/guest/cart/items/{{guestItemId}}",
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"qty\": 2\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Update guest item status is 200', function () { pm.expect(pm.response.code).to.eql(200); });"
                ]
              }
            }
          ]
        },
