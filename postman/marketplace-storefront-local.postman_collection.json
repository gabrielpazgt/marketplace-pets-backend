  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (email/password)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/auth/local/register",
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{registerUsername}}\",\n  \"email\": \"{{registerEmail}}\",\n  \"password\": \"{{registerPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = Date.now();",
                  "pm.collectionVariables.set('registerEmail', `postman_${suffix}@example.com`);",
                  "pm.collectionVariables.set('registerUsername', `postman_${suffix}`);",
                  "if (!pm.collectionVariables.get('registerPassword')) pm.collectionVariables.set('registerPassword', 'Test123456!');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Register status is 200 or 400 (duplicate)', function () { pm.expect(pm.response.code).to.be.oneOf([200, 400]); });",
                  "let json = {}; try { json = pm.response.json(); } catch (e) {}",
                  "if (pm.response.code === 200 && json.jwt) {",
                  "  pm.collectionVariables.set('jwt', json.jwt);",
                  "  pm.collectionVariables.set('userId', String(json.user.id));",
                  "  pm.collectionVariables.set('loginIdentifier', json.user.email);",
                  "  pm.collectionVariables.set('loginPassword', pm.collectionVariables.get('registerPassword'));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (email/password)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/auth/local",
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{loginIdentifier}}\",\n  \"password\": \"{{loginPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.collectionVariables.get('loginIdentifier')) {",
                  "  const fallbackEmail = pm.collectionVariables.get('registerEmail') || 'frontend_test_001@example.com';",
                  "  pm.collectionVariables.set('loginIdentifier', fallbackEmail);",
                  "}",
                  "if (!pm.collectionVariables.get('loginPassword')) {",
                  "  pm.collectionVariables.set('loginPassword', pm.collectionVariables.get('registerPassword') || 'Test123456!');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login status is 200', function () { pm.expect(pm.response.code).to.eql(200); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('jwt', json.jwt);",
                  "pm.collectionVariables.set('userId', String(json.user.id));"
                ]
              }
            }
          ]
        },
        {
          "name": "Users Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt}}"
              }
            ],
            "url": "{{baseUrl}}/api/users/me",
            "description": ""
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Users me status is 200', function () { pm.expect(pm.response.code).to.eql(200); });"
                ]
              }
            }
          ]
        }
      ]
