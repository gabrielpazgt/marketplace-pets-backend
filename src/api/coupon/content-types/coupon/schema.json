{
  "kind": "collectionType",
  "collectionName": "coupons",
  "info": {
    "singularName": "coupon",
    "pluralName": "coupons",
    "displayName": "Coupon"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "code": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "type": {
      "type": "enumeration",
      "required": true,
      "default": "percent",
      "enum": [
        "percent",
        "fixed"
      ]
    },
    "value": {
      "type": "decimal",
      "required": true,
      "min": 0
    },
    "minSubtotal": {
      "type": "decimal",
      "default": 0,
      "min": 0
    },
    "activeFrom": {
      "type": "datetime"
    },
    "activeTo": {
      "type": "datetime"
    },
    "isActive": {
      "type": "boolean",
      "required": true,
      "default": true
    },
    "showInHeaderMarquee": {
      "type": "boolean",
      "default": true
    },
    "usageLimit": {
      "type": "integer"
    },
    "usageCount": {
      "type": "integer",
      "required": false,
      "default": 0
    },
    "eligibleBrands": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::brand.brand"
    },
    "eligibleProducts": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product.product"
    },
    "fundedByBrand": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::brand.brand"
    },
    "influencer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "affiliateCommissionType": {
      "type": "enumeration",
      "enum": [
        "percent",
        "fixed"
      ]
    },
    "affiliateCommissionValue": {
      "type": "decimal",
      "default": 0,
      "min": 0
    },
    "carts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::cart.cart",
      "mappedBy": "coupon"
    },
    "orders": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::order.order",
      "mappedBy": "coupon"
    }
  }
}
