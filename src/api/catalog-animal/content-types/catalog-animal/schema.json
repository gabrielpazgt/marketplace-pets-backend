{
  "kind": "collectionType",
  "collectionName": "catalog_animals",
  "info": {
    "singularName": "catalog-animal",
    "pluralName": "catalog-animals",
    "displayName": "Catalog Animal",
    "description": "Animales principales del catalogo y su contexto editorial."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "key": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "label": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "headline": {
      "type": "string"
    },
    "subtitle": {
      "type": "text"
    },
    "searchHint": {
      "type": "string"
    },
    "navigationImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "legacySpeciesHints": {
      "type": "json"
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "categories": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::catalog-category.catalog-category",
      "mappedBy": "animal"
    }
  }
}
