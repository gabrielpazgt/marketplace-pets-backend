{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "oderNumber": {
      "type": "uid",
      "required": true
    },
    "orderNumber": {
      "type": "string",
      "unique": true
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "orders"
    },
    "email": {
      "type": "string",
      "required": true
    },
    "billingAddress": {
      "type": "json",
      "required": true
    },
    "shippingAddress": {
      "type": "json",
      "required": true
    },
    "currency": {
      "type": "string",
      "default": "GTQ",
      "required": true
    },
    "subtotal": {
      "type": "decimal",
      "required": true,
      "default": 0,
      "min": 0
    },
    "discountTotal": {
      "type": "decimal",
      "required": true,
      "default": 0,
      "min": 0
    },
    "shippingTotal": {
      "type": "decimal",
      "required": true,
      "default": 0,
      "min": 0
    },
    "taxTotal": {
      "type": "decimal",
      "default": 0,
      "min": 0
    },
    "grandTotal": {
      "type": "decimal",
      "required": true,
      "default": 0,
      "min": 0
    },
    "membershipApplied": {
      "type": "boolean",
      "default": false
    },
    "statusOrder": {
      "type": "enumeration",
      "required": true,
      "default": "pending",
      "enum": [
        "pending",
        "paid",
        "processing",
        "shipped",
        "delivered",
        "cancelled",
        "refunded"
      ]
    },
    "order_items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::order-item.order-item",
      "mappedBy": "order"
    },
    "coupon": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::coupon.coupon",
      "inversedBy": "orders"
    },
    "couponCode": {
      "type": "string"
    },
    "couponScope": {
      "type": "enumeration",
      "enum": [
        "global",
        "brand",
        "product",
        "mixed"
      ]
    },
    "couponEligibleSubtotal": {
      "type": "decimal",
      "default": 0,
      "min": 0
    },
    "couponFundedByBrand": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::brand.brand"
    },
    "couponInfluencer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "affiliateCommissionType": {
      "type": "enumeration",
      "enum": [
        "percent",
        "fixed"
      ]
    },
    "affiliateCommissionValue": {
      "type": "decimal",
      "default": 0,
      "min": 0
    },
    "affiliateCommissionAmount": {
      "type": "decimal",
      "default": 0,
      "min": 0
    }
  }
}
