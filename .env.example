HOST=0.0.0.0
PORT=1338
PUBLIC_URL=http://localhost:1338
CORS_ORIGIN=http://localhost:4200,http://127.0.0.1:4200
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

DATABASE_CLIENT=postgres
DATABASE_HOST=db.<your-project-ref>.supabase.co
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=change_me
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true
PGSSLMODE=verify-full
# DATABASE_SSL_CA=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
DATABASE_SCHEMA=public
DATABASE_POOL_MIN=0
DATABASE_POOL_MAX=5
# DATABASE_URL=postgresql://postgres.<your-project-ref>:YOUR_DB_PASSWORD@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# Password reset URL used by users-permissions email template
UP_RESET_PASSWORD_URL=http://localhost:4200/auth/reset-password

# Email provider (sendmail | nodemailer)
EMAIL_PROVIDER=nodemailer
EMAIL_DEFAULT_FROM=Marketplace <no-reply@yourdomain.com>
EMAIL_DEFAULT_REPLY_TO=support@yourdomain.com

# SMTP (required when EMAIL_PROVIDER=nodemailer)
SMTP_HOST=smtp-relay.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_USERNAME=your_smtp_user
SMTP_PASSWORD=your_smtp_password
