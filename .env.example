# ────────────────────────────────────────────────
# SERVER
# ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=1338
# URL pública del backend (sin trailing slash) — se usa en OAuth callbacks, sitemap, merchant feed, etc.
PUBLIC_URL=http://localhost:1338
# URL pública del frontend — se usa en el link de reset de contraseña del email
FRONTEND_PUBLIC_URL=http://localhost:4200

# Orígenes permitidos por CORS (separados por coma, sin espacios)
CORS_ORIGIN=http://localhost:4200,http://127.0.0.1:4200

# ────────────────────────────────────────────────
# NODE / STRAPI SECRETS  (generar con: openssl rand -base64 32)
# ────────────────────────────────────────────────
NODE_ENV=development
APP_KEYS="key1base64==,key2base64==,key3base64==,key4base64=="
API_TOKEN_SALT=changeme_base64
ADMIN_JWT_SECRET=changeme_base64
TRANSFER_TOKEN_SALT=changeme_base64
JWT_SECRET=changeme_base64
ENCRYPTION_KEY=changeme_base64

# ────────────────────────────────────────────────
# DATABASE (Postgres / Supabase)
# ────────────────────────────────────────────────
DATABASE_CLIENT=postgres
DATABASE_HOST=db.<your-project-ref>.supabase.co
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USERNAME=postgres.<your-project-ref>
DATABASE_PASSWORD=change_me
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true
PGSSLMODE=require
DATABASE_SCHEMA=public
DATABASE_POOL_MIN=0
DATABASE_POOL_MAX=5
# Alternativa: usar URL de conexión directa (session pooler)
# DATABASE_URL=postgresql://postgres.<ref>:PASSWORD@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# ────────────────────────────────────────────────
# EMAIL
# ────────────────────────────────────────────────
# URL para el link de "resetear contraseña" que Strapi envía por email
UP_RESET_PASSWORD_URL=http://localhost:4200/auth/reset-password

# Proveedor: sendmail | nodemailer
EMAIL_PROVIDER=nodemailer
EMAIL_DEFAULT_FROM=Aumakki Marketplace <no-reply@aumakki.com>
EMAIL_DEFAULT_REPLY_TO=soporte@aumakki.com

# SMTP (requerido cuando EMAIL_PROVIDER=nodemailer)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_USERNAME=your_smtp_user
SMTP_PASSWORD=your_smtp_password

# ────────────────────────────────────────────────
# SUPABASE STORAGE  (mismo proyecto que la DB)
# apiKey: usar la "service_role" key (Settings → API)
# bucket: crear uno público llamado "uploads" en Storage
# ────────────────────────────────────────────────
SUPABASE_API_URL=https://<your-project-ref>.supabase.co
SUPABASE_API_KEY=your_service_role_key
SUPABASE_BUCKET=uploads
SUPABASE_DIRECTORY=

# ────────────────────────────────────────────────
# GOOGLE OAUTH  (Google Cloud Console → Credenciales)
# ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ────────────────────────────────────────────────
# USUARIO OPERATIVO (se crea automáticamente al arrancar)
# ────────────────────────────────────────────────
OPS_USER_USERNAME=AumakkiAdmin
OPS_USER_EMAIL=admin@aumakki.com
OPS_USER_PASSWORD=change_me_in_production
